# Used by local stdio mode only.
POSTORIA_API_KEY=pst_live_your_api_key_here

# Optional. Defaults to https://api.postoria.io/v1.
POSTORIA_API_BASE_URL=https://api.postoria.io/v1

# HTTP transport settings.
# HTTP mode requires clients to send Authorization: Bearer <token> on every /mcp request.
PORT=3000
MCP_PATH=/mcp
MCP_SESSION_MAX_AGE_MS=3600000

# OAuth protected resource metadata for hosted HTTP mode.
# Required when MCP clients discover OAuth from the hosted endpoint.
MCP_PUBLIC_URL=https://mcp.example.com/mcp
OAUTH_PROTECTED_RESOURCE_METADATA_URL=https://mcp.example.com/.well-known/oauth-protected-resource/mcp
OAUTH_AUTHORIZATION_SERVER=https://login.example.com/realms/example
OAUTH_SCOPES=

# Comma-separated allowed origins for hosted HTTP mode.
# Leave empty for local development. Set this for production.
ALLOWED_ORIGINS=https://chatgpt.com,https://claude.ai
