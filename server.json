{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.postoria/mcp-server",
  "title": "Postoria",
  "description": "MCP server for the Postoria Public API. Create, schedule, queue, inspect, and delete Postoria posts through AI agents.",
  "version": "1.0.2",
  "websiteUrl": "https://postoria.io",
  "repository": {
    "url": "https://github.com/postoria-app/postoria-mcp-server",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.postoria.io/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer Postoria API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@postoria/mcp-server",
      "version": "1.0.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "POSTORIA_API_KEY",
          "description": "Your Postoria API key",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "POSTORIA_API_BASE_URL",
          "description": "Optional API base URL. Defaults to https://api.postoria.io/v1.",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ]
}
